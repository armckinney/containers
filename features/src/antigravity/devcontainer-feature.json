{
  "id": "antigravity",
  "version": "1.1.0",
  "name": "Antigravity CLI",
  "description": "Installs Google's Antigravity CLI (agy) and mounts local config files from the host.",
  "documentationURL": "https://github.com/armckinney/containers/blob/main/features/src/antigravity",
  "options": {},
  "mounts": [
    {
      "source": "${localEnv:HOME}/.gemini",
      "target": "/root/.gemini",
      "type": "bind"
    }
  ]
}
