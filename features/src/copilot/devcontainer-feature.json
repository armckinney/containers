{
  "id": "copilot",
  "version": "1.0.0",
  "name": "GitHub Copilot",
  "description": "Installs the GitHub Copilot CLI and configures GitHub Copilot VS Code extensions.",
  "documentationURL": "https://github.com/armckinney/containers/blob/main/features/src/copilot",
  "options": {},
  "mounts": [
    {
      "source": "${localEnv:HOME}/.copilot",
      "target": "/root/.copilot",
      "type": "bind"
    }
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ]
    }
  }
}
