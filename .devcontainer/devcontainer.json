{
  "name": "containers",
  "dockerComposeFile": [
    "docker-compose.yaml"
  ],
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/containers",
  "initializeCommand": "ln -snf ../features/src .devcontainer/features",
  "postCreateCommand": "cd $WORKSPACE/",
  "features": {
    "./features/docker-in-docker": {},
    "./features/copilot": {}
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          }
        },
        "files.exclude": {
          "**/.git": true,
          "**/.svn": true,
          "**/.hg": true,
          "**/CVS": true,
          "**/.DS_Store": true,
          "**/bin": true,
          "**/obj": true,
          "**/.vs": true
        }
      },
      "extensions": [
        "ms-azuretools.vscode-docker",
        "yzhang.markdown-all-in-one",
        "bierner.markdown-mermaid",
        "github.vscode-github-actions"
      ]
    }
  }
}